        "schemaType": "manual",
        "inputSchema": "{\n  \"type\": \"object\",\n  \"properties\": {\n\n    \"candidate_strengths\": {\n      \"type\": \"array\",\n      \"description\": \"2 to 4 specific strengths with evidence from the resume.\",\n      \"minItems\": 2,\n      \"maxItems\": 4,\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"title\":  { \"type\": \"string\", \"description\": \"Short label, e.g. 'Strong Python background'.\" },\n          \"detail\": { \"type\": \"string\", \"description\": \"Evidence-backed elaboration from the resume.\" }\n        },\n        \"required\": [\"title\", \"detail\"]\n      }\n    },\n\n    \"candidate_weaknesses\": {\n      \"type\": \"array\",\n      \"description\": \"2 to 3 specific gaps based on the JD requirements.\",\n      \"minItems\": 2,\n      \"maxItems\": 3,\n      \"items\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"title\":    { \"type\": \"string\", \"description\": \"Short label, e.g. 'No cloud experience'.\" },\n          \"severity\": {\n            \"type\": \"string\",\n            \"enum\": [\"Minor\", \"Moderate\", \"Critical\"],\n            \"description\": \"How blocking this gap is for the role.\"\n          },\n          \"detail\":   { \"type\": \"string\", \"description\": \"Explanation of the gap and its hiring impact.\" }\n        },\n        \"required\": [\"title\", \"severity\", \"detail\"]\n      }\n    },\n\n    \"risk_factor\": {\n      \"type\": \"object\",\n      \"description\": \"Potential downside of hiring this candidate.\",\n      \"properties\": {\n        \"score\": {\n          \"type\": \"string\",\n          \"enum\": [\"Low\", \"Medium\", \"High\"]\n        },\n        \"explanation\": {\n          \"type\": \"string\",\n          \"description\": \"Worst-case scenario if the candidate is hired and underperforms.\"\n        }\n      },\n      \"required\": [\"score\", \"explanation\"]\n    },\n\n    \"reward_factor\": {\n      \"type\": \"object\",\n      \"description\": \"Potential upside of hiring this candidate.\",\n      \"properties\": {\n        \"score\": {\n          \"type\": \"string\",\n          \"enum\": [\"Low\", \"Medium\", \"High\"]\n        },\n        \"fit_horizon\": {\n          \"type\": \"string\",\n          \"enum\": [\"Short-term\", \"Long-term\", \"Both\"],\n          \"description\": \"Whether the candidate is a short-term executor or long-term growth bet.\"\n        },\n        \"explanation\": {\n          \"type\": \"string\",\n          \"description\": \"Best-case scenario and strategic value if the candidate thrives.\"\n        }\n      },\n      \"required\": [\"score\", \"fit_horizon\", \"explanation\"]\n    },\n\n    \"justification_rating\": {\n      \"type\": \"object\",\n      \"description\": \"How well the resume evidences the candidate's claimed skills.\",\n      \"properties\": {\n        \"score\": {\n          \"type\": \"number\",\n          \"minimum\": 0,\n          \"maximum\": 10,\n          \"description\": \"0–10. How credible and evidence-backed are the resume claims.\"\n        },\n        \"confidence_level\": {\n          \"type\": \"string\",\n          \"enum\": [\"Unverifiable\", \"Weak\", \"Moderate\", \"Strong\", \"Exceptional\"]\n        },\n        \"red_flags\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" },\n          \"description\": \"Inconsistencies, vague claims, or unsupported assertions in the resume.\"\n        },\n        \"supporting_evidence\": {\n          \"type\": \"array\",\n          \"items\": { \"type\": \"string\" },\n          \"description\": \"Concrete examples — metrics, projects, outcomes — that back the candidate's claims.\"\n        },\n        \"explanation\": {\n          \"type\": \"string\",\n          \"description\": \"Overall reasoning for the justification score.\"\n        }\n      },\n      \"required\": [\"score\", \"confidence_level\", \"explanation\"]\n    },\n\n    \"overfit_rating\": {\n      \"type\": \"object\",\n      \"description\": \"Whether the candidate is overqualified and may disengage or leave early.\",\n      \"properties\": {\n        \"is_overfit\": {\n          \"type\": \"boolean\"\n        },\n        \"severity\": {\n          \"type\": \"string\",\n          \"enum\": [\"None\", \"Slight\", \"Moderate\", \"Severe\"]\n        },\n        \"retention_risk\": {\n          \"type\": \"string\",\n          \"enum\": [\"Low\", \"Medium\", \"High\"]\n        },\n        \"explanation\": {\n          \"type\": \"string\"\n        }\n      },\n      \"required\": [\"is_overfit\", \"severity\", \"retention_risk\", \"explanation\"]\n    },\n\n    \"executive_summary\": {\n      \"type\": \"string\",\n      \"description\": \"2–3 sentence summary of the final hiring decision and rationale.\"\n    }\n\n  },\n  \"required\": [\n    \"candidate_strengths\",\n    \"candidate_weaknesses\",\n    \"risk_factor\",\n    \"reward_factor\",\n    \"justification_rating\",\n    \"overfit_rating\",\n    \"executive_summary\"\n  ]\n}"
