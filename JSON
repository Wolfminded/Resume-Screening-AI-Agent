    {
      "parameters": {
        "jsCode": "// === SCORING ENGINE ===\n\n// Safely get output — already an object OR a raw string\nfunction safeGet(raw) {\n  if (typeof raw === 'object' && raw !== null) return raw;   // already parsed\n  if (typeof raw === 'string') {\n    const cleaned = raw\n      .replace(/^```json\\s*/i, '')\n      .replace(/^```\\s*/i, '')\n      .replace(/```\\s*$/i, '')\n      .trim();\n    return JSON.parse(cleaned);\n  }\n  return {};\n}\n\nconst matchingOutput = safeGet($('🧩 Matching Agent').item.json.output);\nconst parserOutput   = safeGet($('🧩 Parser Agent').item.json.output);\n\nconst candidate   = parserOutput.candidate || {};\nconst job         = parserOutput.job       || {};\n\nconst matched  = Array.isArray(matchingOutput.matched_skills) ? matchingOutput.matched_skills : [];\nconst missing  = Array.isArray(matchingOutput.missing_skills) ? matchingOutput.missing_skills : [];\n\nconst total    = matched.length + missing.length;\nconst matchPct = total > 0 ? Math.round((matched.length / total) * 100) : 0;\n\nconst expYears    = Number(candidate.total_experience_years) || 0;\nconst requiredExp = Number(job.required_experience_years)    || 3;\n\nconst expScore       = Math.min((expYears / requiredExp) * 100, 100);\nconst compositeScore = Math.round((matchPct * 0.65) + (expScore * 0.35));\n\nlet tier = 'No Hire';\nif      (compositeScore >= 80) tier = 'Strong Hire';\nelse if (compositeScore >= 65) tier = 'Hire';\nelse if (compositeScore >= 45) tier = 'Maybe';\n\nlet nextStep = 'Reject';\nif      (tier === 'Strong Hire') nextStep = 'Advance to Technical Round';\nelse if (tier === 'Hire')        nextStep = 'Advance to HR Round';\nelse if (tier === 'Maybe')       nextStep = 'Request Portfolio / Work Samples';\n\nreturn [{\n  json: {\n    scoring: {\n      skill_match_pct:       matchPct,\n      experience_score:      Math.round(expScore),\n      composite_score:       compositeScore,\n      tier:                  tier,\n      recommended_next_step: nextStep,\n      breakdown: { skill_weight: '65%', experience_weight: '35%' }\n    },\n    candidate:      candidate,\n    job:            job,\n    matched_skills: matched,\n    missing_skills: missing,\n    bonus_skills:   Array.isArray(matchingOutput.bonus_skills) ? matchingOutput.bonus_skills : []\n  }\n}];"
      },
