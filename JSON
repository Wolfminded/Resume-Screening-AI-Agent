      "parameters": {
        "jsCode": "// === 🧩 CONFIDENCE VALIDATOR ===\n\nfunction safeGet(raw) {\n  if (typeof raw === 'object' && raw !== null) return raw;\n  if (typeof raw === 'string') {\n    const cleaned = raw\n      .replace(/^```json\\s*/i, '')\n      .replace(/^```\\s*/i, '')\n      .replace(/```\\s*$/i, '')\n      .trim();\n    return JSON.parse(cleaned);\n  }\n  return {};\n}\n\nconst decision = safeGet($('🧩 Decision Agent').item.json.output);\nconst scoring  = $('🧩 Scoring Engine (Code)').item.json.scoring  || {};\nconst matching = safeGet($('🧩 Matching Agent').item.json.output);\n\nlet issues     = [];\nlet confidence = 1.0;\n\n// ── CHECK 1: Justification score must exist and be a valid number ──\nconst justScore = decision.justification_rating?.score;\nif (justScore == null || typeof justScore !== 'number') {\n  issues.push('Missing or invalid justification_rating.score');\n  confidence -= 0.3;\n}\n\n// ── CHECK 2: Strengths must exist and have content ─────────────────\nconst strengths = decision.candidate_strengths;\nif (!Array.isArray(strengths) || strengths.length === 0) {\n  issues.push('candidate_strengths missing or empty');\n  confidence -= 0.2;\n} else if (strengths.some(s => !s.title || !s.detail)) {\n  issues.push('One or more strengths missing title or detail');\n  confidence -= 0.1;\n}\n\n// ── CHECK 3: Weaknesses must exist and have severity ──────────────\nconst weaknesses = decision.candidate_weaknesses;\nif (!Array.isArray(weaknesses) || weaknesses.length === 0) {\n  issues.push('candidate_weaknesses missing or empty');\n  confidence -= 0.15;\n} else if (weaknesses.some(w => !['Minor','Moderate','Critical'].includes(w.severity))) {\n  issues.push('One or more weaknesses have invalid severity value');\n  confidence -= 0.1;\n}\n\n// ── CHECK 4: Executive summary must be substantive ─────────────────\nconst summary = decision.executive_summary || '';\nif (summary.length < 20) {\n  issues.push('executive_summary missing or too short (< 20 chars)');\n  confidence -= 0.2;\n}\n\n// ── CHECK 5: Risk and Reward factors must have valid scores ────────\nconst validScores = ['Low', 'Medium', 'High'];\nif (!validScores.includes(decision.risk_factor?.score)) {\n  issues.push('risk_factor.score missing or invalid');\n  confidence -= 0.1;\n}\nif (!validScores.includes(decision.reward_factor?.score)) {\n  issues.push('reward_factor.score missing or invalid');\n  confidence -= 0.1;\n}\n\n// ── CHECK 6: Skill matching must have produced results ─────────────\nconst matched = matching.matched_skills;\nconst missing = matching.missing_skills;\nif (!Array.isArray(matched) || !Array.isArray(missing)) {\n  issues.push('Matching Agent output malformed — matched/missing_skills not arrays');\n  confidence -= 0.25;\n} else if (matched.length === 0 && missing.length === 0) {\n  issues.push('Both matched_skills and missing_skills are empty — likely parse failure');\n  confidence -= 0.2;\n}\n\n// ── CHECK 7: Composite score must be a real number ─────────────────\nif (typeof scoring.composite_score !== 'number' || isNaN(scoring.composite_score)) {\n  issues.push('Scoring Engine composite_score is missing or NaN');\n  confidence -= 0.15;\n}\n\n// ── FINAL VERDICT ──────────────────────────────────────────────────\nconst finalConfidence = Math.max(0, parseFloat(confidence.toFixed(2)));\nconst shouldRetry     = finalConfidence < 0.6;\n\nreturn [{\n  json: {\n    confidence:   finalConfidence,\n    should_retry: shouldRetry,\n    pass:         !shouldRetry,\n    issues:       issues,\n    checks_run:   7,\n    checks_failed: issues.length,\n    // Pass decision through so Merge Final Output can read it directly\n    decision:     decision,\n    scoring:      scoring,\n    matching:     matching\n  }\n}];"
      },
